# LLM API Provider Configuration
# Default proxy: fxb.supa.net.cn:6443 (OpenAI-compatible, requires key from AI4SS Team)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://fxb.supa.net.cn:6443
LLM_MODEL=deepseek-v4-flash

# API Format: "openai" (default, /v1/chat/completions + Bearer token)
#             "anthropic" (/v1/messages + x-api-key header)
# Most Chinese LLM proxies (one-api, new-api) use "openai" format
LLM_API_FORMAT=openai

# (Optional) Fallback API Key for DeepSeek official endpoint
# Used automatically when the primary proxy returns 401/403
LLM_FALLBACK_API_KEY=

# DNS connection patch: bypasses DNS pollution for fxb.supa.net.cn
ENABLE_LLM_DNS_PATCH=true

# OpenAlex API Configuration (Optional, improves rate limits)
OPENALEX_EMAIL=your_email@example.com

# Feature extraction speed tuning (Layer 2: LLM per-paper extraction)
# Higher = faster; lower them if you hit HTTP 429 rate-limit errors
LLM_EXTRACT_QPS=4
LLM_EXTRACT_WORKERS=8

# HuggingFace model download (for sentence-transformers semantic similarity)
# network_config.py defaults to the hf-mirror.com mirror for CN networks.
# Overseas users can set back to https://huggingface.co
HF_ENDPOINT=https://hf-mirror.com
# Set to 1 for fully offline mode: use local model cache only;
# falls back to BoW word-frequency similarity instantly if cache is missing
HF_HUB_OFFLINE=0
