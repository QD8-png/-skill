# LLM API Provider Configuration
# Uses Anthropic Messages API format (x-api-key header + /v1/messages endpoint)
# Default proxy: fxb.supa.net.cn (requires activation key from AI4SS Team)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://fxb.supa.net.cn:6443
LLM_MODEL=deepseek-v4-flash

# (Optional) Fallback API Key for DeepSeek official endpoint
# Used automatically when the primary proxy returns 401/403
LLM_FALLBACK_API_KEY=

# DNS connection patch: bypasses DNS pollution for fxb.supa.net.cn
ENABLE_LLM_DNS_PATCH=true

# OpenAlex API Configuration (Optional, improves rate limits)
OPENALEX_EMAIL=your_email@example.com
